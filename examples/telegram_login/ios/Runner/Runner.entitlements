<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE plist PUBLIC '-//Apple//DTD PLIST 1.0//EN' 'http://www.apple.com/DTDs/PropertyList-1.0.dtd'>
<plist version='1.0'>
<dict>
	<!-- Associated Domains for Telegram Login.
	     - `applinks:` is required so the HTTPS callback URL returned from the
	       authorization server opens the app via Universal Links.
	     - `webcredentials:` is required because ASWebAuthenticationSession's
	       HTTPS callback mode (iOS 17.4+) explicitly refuses to run unless the
	       app is associated with the callback host via the `webcredentials`
	       service type. Without it, the session fails with:
	         "Using HTTPS callbacks requires Associated Domains using the
	          `webcredentials` service type for <host>."
	     - During development you can append `?mode=developer` to each entry
	       to force iOS to bypass Apple's CDN and re-fetch the AASA file on
	       every launch (requires enabling Settings → Developer → Associated
	       Domains Development on the device). -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:app2142222789-login.tg.dev</string>
		<string>webcredentials:app2142222789-login.tg.dev</string>
	</array>
</dict>
</plist>